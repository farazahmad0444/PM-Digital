{{ 'bundle-banner.css' | asset_url | stylesheet_tag }}

{% liquid
  assign bundle_banner_first_section = false
  if section.index == 1
    assign bundle_banner_first_section = true
  endif
  assign bundle_banner_text_color = section.settings.text_color | default: '#ffffff'
  assign bundle_banner_highlight_color = section.settings.highlight_color | default: '#5eb8d0'
%}

{% for block in section.blocks %}
  {% if block.type == 'heading' %}
    {% assign heading_block = block %}
  {% elsif block.type == 'description' %}
    {% assign description_block = block %}
  {% elsif block.type == 'cta' %}
    {% assign cta_block = block %}
  {% elsif block.type == 'product_image' %}
    {% assign product_image_block = block %}
  {% endif %}
{% endfor %}

<section class="bundle-banner" data-testid="bundle-banner-{{ section.id }}" aria-labelledby="bundle-banner-heading-{{ section.id }}" style="--bundle-banner-text-color: {{ bundle_banner_text_color }}; --bundle-banner-highlight-color: {{ bundle_banner_highlight_color }};">
  <div class="bundle-banner__background">
    {% if section.settings.background_image != blank or section.settings.background_image_mobile != blank %}
      <picture class="bundle-banner__background-picture">
        {% if section.settings.background_image_mobile != blank and section.settings.background_image != blank %}
          <source
            media="(max-width: 749px)"
            srcset="{{ section.settings.background_image_mobile | image_url: width: 750 }} 750w,
                    {{ section.settings.background_image_mobile | image_url: width: 800 }} 800w"
            sizes="100vw"
          >
        {% endif %}
        {% if section.settings.background_image != blank %}
          <img
            class="bundle-banner__background-image"
            src="{{ section.settings.background_image | image_url: width: 1600 }}"
            srcset="{{ section.settings.background_image | image_url: width: 800 }} 800w,
                    {{ section.settings.background_image | image_url: width: 1200 }} 1200w,
                    {{ section.settings.background_image | image_url: width: 1600 }} 1600w"
            sizes="100vw"
            alt=""
            width="{{ section.settings.background_image.width }}"
            height="{{ section.settings.background_image.height }}"
            loading="{% if bundle_banner_first_section %}eager{% else %}lazy{% endif %}"
            fetchpriority="{% if bundle_banner_first_section %}high{% else %}low{% endif %}"
          >
        {% elsif section.settings.background_image_mobile != blank %}
          <img
            class="bundle-banner__background-image"
            src="{{ section.settings.background_image_mobile | image_url: width: 750 }}"
            srcset="{{ section.settings.background_image_mobile | image_url: width: 750 }} 750w,
                    {{ section.settings.background_image_mobile | image_url: width: 800 }} 800w"
            sizes="100vw"
            alt=""
            width="{{ section.settings.background_image_mobile.width }}"
            height="{{ section.settings.background_image_mobile.height }}"
            loading="{% if bundle_banner_first_section %}eager{% else %}lazy{% endif %}"
            fetchpriority="{% if bundle_banner_first_section %}high{% else %}low{% endif %}"
          >
        {% endif %}
      </picture>
    {% endif %}
  </div>

  <div class="bundle-banner__inner">
    <div class="bundle-banner__content">
      {% if heading_block %}
        <h2 id="bundle-banner-heading-{{ section.id }}" class="bundle-banner__heading">
          {{ heading_block.settings.heading | escape }}
          {% if heading_block.settings.heading_highlight != blank %}
            <span class="bundle-banner__heading-highlight">{{ heading_block.settings.heading_highlight | escape }}</span>
          {% endif %}
        </h2>
      {% endif %}
      {% if description_block and description_block.settings.description != blank %}
        <p class="bundle-banner__subheading">{{ description_block.settings.description | escape }}</p>
      {% endif %}
      {% if cta_block and cta_block.settings.cta_label != blank and cta_block.settings.cta_link != blank %}
        <a href="{{ cta_block.settings.cta_link }}" class="bundle-banner__cta">
          {{ cta_block.settings.cta_label | escape }}
        </a>
      {% endif %}
    </div>

    {% if product_image_block %}
      {% if product_image_block.settings.product_image != blank or product_image_block.settings.product_image_mobile != blank %}
      <div class="bundle-banner__media">
        <picture class="bundle-banner__product-picture">
          {% if product_image_block.settings.product_image_mobile != blank and product_image_block.settings.product_image != blank %}
            <source
              media="(max-width: 749px)"
              srcset="{{ product_image_block.settings.product_image_mobile | image_url: width: 750 }} 750w"
              sizes="750px"
            >
          {% endif %}
          {% if product_image_block.settings.product_image != blank %}
            <img
              class="bundle-banner__product-image"
              src="{{ product_image_block.settings.product_image | image_url: width: 1440 }}"
              srcset="{{ product_image_block.settings.product_image | image_url: width: 720 }} 720w,
                      {{ product_image_block.settings.product_image | image_url: width: 1440 }} 1440w"
              sizes="(min-width: 990px) 220px, (min-width: 750px) 180px, 140px"
              alt="{{ product_image_block.settings.product_image_alt | default: 'Bundle product' | escape }}"
              width="{{ product_image_block.settings.product_image.width }}"
              height="{{ product_image_block.settings.product_image.height }}"
              loading="{% if bundle_banner_first_section %}eager{% else %}lazy{% endif %}"
              fetchpriority="{% if bundle_banner_first_section %}high{% else %}auto{% endif %}"
            >
          {% elsif product_image_block.settings.product_image_mobile != blank %}
            <img
              class="bundle-banner__product-image"
              src="{{ product_image_block.settings.product_image_mobile | image_url: width: 750 }}"
              srcset="{{ product_image_block.settings.product_image_mobile | image_url: width: 750 }} 750w"
              sizes="750px"
              alt="{{ product_image_block.settings.product_image_alt | default: 'Bundle product' | escape }}"
              width="{{ product_image_block.settings.product_image_mobile.width }}"
              height="{{ product_image_block.settings.product_image_mobile.height }}"
              loading="{% if bundle_banner_first_section %}eager{% else %}lazy{% endif %}"
              fetchpriority="{% if bundle_banner_first_section %}high{% else %}auto{% endif %}"
            >
          {% endif %}
        </picture>
      </div>
      {% endif %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Bundle banner",
  "tag": "section",
  "class": "section-bundle-banner",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight color",
      "default": "#5eb8d0",
      "info": "Used for heading highlight and CTA button"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Smart stack, smarter price - shop curated bundles and"
        },
        {
          "type": "text",
          "id": "heading_highlight",
          "label": "Heading highlight",
          "default": "save 30%.",
          "info": "Optional text shown in accent color"
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Clinically informed formulas that support energy, balance, and everyday wellness."
        }
      ]
    },
    {
      "type": "cta",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Shop bundles"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA link",
          "info": "Collection, product, or any custom URL"
        }
      ]
    },
    {
      "type": "product_image",
      "name": "Product image",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product image (desktop)"
        },
        {
          "type": "image_picker",
          "id": "product_image_mobile",
          "label": "Product image (mobile)"
        },
        {
          "type": "text",
          "id": "product_image_alt",
          "label": "Product image alt text",
          "info": "Describe the product for accessibility (used for desktop and mobile)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundle banner",
      "settings": {
        "text_color": "#ffffff",
        "highlight_color": "#5eb8d0"
      },
      "blocks": [
        {
          "type": "heading",
          "settings": {
            "heading": "Smart stack, smarter price - shop curated bundles and",
            "heading_highlight": "save 30%."
          }
        },
        {
          "type": "description",
          "settings": {
            "description": "Clinically informed formulas that support energy, balance, and everyday wellness."
          }
        },
        {
          "type": "cta",
          "settings": {
            "cta_label": "Shop bundles"
          }
        },
        {
          "type": "product_image"
        }
      ]
    }
  ]
}
{% endschema %}
